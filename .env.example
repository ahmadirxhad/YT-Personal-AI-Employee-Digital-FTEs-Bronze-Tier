# AI Employee Bronze Tier — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.

# ── Vault ───────────────────────────────────────────────────────────────────
# Absolute or relative path to your Obsidian vault folder
VAULT_PATH=../AI_Employee_Vault

# ── Orchestrator ────────────────────────────────────────────────────────────
# Set to 'false' when you are ready for live operation
DRY_RUN=true

# How often the orchestrator checks for new tasks (seconds)
CHECK_INTERVAL=30

# Claude Code CLI command (usually 'claude')
CLAUDE_CMD=claude

# ── Gmail Watcher ───────────────────────────────────────────────────────────
# Path to your Google OAuth2 credentials file (from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=./credentials.json

# Path where the OAuth token will be saved after first login
GMAIL_TOKEN_PATH=./token.json

# ── Filesystem Watcher ──────────────────────────────────────────────────────
# Folder to watch for dropped files (drag files here to trigger AI Employee)
# Uses the Obsidian vault Inbox folder — drop files here directly in Obsidian
DROP_FOLDER=../AI_Employee_Vault/Inbox

# ── Security ────────────────────────────────────────────────────────────────
# Rate limits (actions per hour — prevents runaway automation)
MAX_EMAILS_PER_HOUR=10
MAX_ACTIONS_PER_HOUR=20
